<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- Header / Barra Superior -->
    <View
        android:id="@+id/headerBackground"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:background="@color/primary_blue"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/ivBack"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:src="@drawable/ic_back_white"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvWelcome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:text="Hola, Carlos"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/ivBack"
        app:layout_constraintStart_toEndOf="@id/ivBack"
        app:layout_constraintTop_toTopOf="@id/ivBack" />

    <ImageView
        android:id="@+id/ivNotification"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginEnd="16dp"
        android:src="@android:drawable/ic_popup_reminder"
        app:layout_constraintBottom_toBottomOf="@id/ivBack"
        app:layout_constraintEnd_toStartOf="@id/ivProfile"
        app:layout_constraintTop_toTopOf="@id/ivBack"
        app:tint="@color/white" />

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/ivProfile"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginEnd="16dp"
        android:scaleType="centerCrop"
        android:src="@android:drawable/ic_menu_myplaces"
        app:layout_constraintBottom_toBottomOf="@id/ivBack"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/ivBack"
        app:shapeAppearanceOverlay="@style/CircleImage" />

    <!-- Card de Información del Estudiante -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cvStudentInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="-40dp"
        android:layout_marginEnd="16dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/headerBackground">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivStudent"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@android:drawable/ic_menu_directions"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:shapeAppearanceOverlay="@style/CircleImage" />

            <TextView
                android:id="@+id/tvStudentName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Mateo Gomez"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintStart_toEndOf="@id/ivStudent"
                app:layout_constraintTop_toTopOf="@id/ivStudent" />

            <TextView
                android:id="@+id/tvRoute"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ruta: Norte 3"
                android:textColor="@color/gray_text"
                android:textSize="12sp"
                app:layout_constraintStart_toStartOf="@id/tvStudentName"
                app:layout_constraintTop_toBottomOf="@id/tvStudentName" />

            <TextView
                android:id="@+id/tvBus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bus: ABC 123 (12)"
                android:textColor="@color/gray_text"
                android:textSize="12sp"
                app:layout_constraintStart_toStartOf="@id/tvStudentName"
                app:layout_constraintTop_toBottomOf="@id/tvRoute" />

            <TextView
                android:id="@+id/tvDriver"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Conductor: Luis Martinez"
                android:textColor="@color/gray_text"
                android:textSize="12sp"
                app:layout_constraintStart_toStartOf="@id/tvStudentName"
                app:layout_constraintTop_toBottomOf="@id/tvBus" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Estado: En camino"
                android:textColor="@color/gray_text"
                android:textSize="12sp"
                app:layout_constraintStart_toStartOf="@id/tvStudentName"
                app:layout_constraintTop_toBottomOf="@id/tvDriver" />

            <!-- Mapa / Trayecto (Placeholder) -->
            <ImageView
                android:id="@+id/ivMapPlaceholder"
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:layout_marginTop="16dp"
                android:scaleType="centerCrop"
                android:src="@android:drawable/dialog_holo_light_frame"
                app:layout_constraintTop_toBottomOf="@id/tvStatus" />

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@android:drawable/ic_menu_mylocation"
                app:layout_constraintBottom_toBottomOf="@id/ivMapPlaceholder"
                app:layout_constraintEnd_toEndOf="@id/ivMapPlaceholder"
                app:layout_constraintStart_toStartOf="@id/ivMapPlaceholder"
                app:layout_constraintTop_toTopOf="@id/ivMapPlaceholder" />

            <!-- Lista de paradas -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical"
                app:layout_constraintTop_toBottomOf="@id/ivMapPlaceholder">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:drawableStart="@drawable/ic_warning_dark"
                    android:drawablePadding="8dp"
                    android:text="La ruta se encuentra a 4km de distancia"
                    android:textColor="@color/gray_text"
                    android:textSize="12sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:drawableStart="@drawable/ic_check_green"
                    android:drawablePadding="8dp"
                    android:text="Colegio cambridge School"
                    android:textColor="@color/black" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:drawableStart="@drawable/ic_check_green"
                    android:drawablePadding="8dp"
                    android:text="Primer parada"
                    android:textColor="@color/black" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="#E07C4E"
                    android:padding="8dp"
                    android:drawableStart="@android:drawable/ic_delete"
                    android:drawablePadding="8dp"
                    android:text="Segunda parada (actual)"
                    android:textColor="@color/white" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:drawableStart="@android:drawable/presence_busy"
                    android:drawablePadding="8dp"
                    android:text="Tercer parada"
                    android:textColor="@color/black" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:drawableStart="@android:drawable/presence_busy"
                    android:drawablePadding="8dp"
                    android:text="Destino (casa)"
                    android:textColor="@color/black" />
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Botones Inferiores -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnViewRoute"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:backgroundTint="@color/primary_blue"
            android:text="Ver ruta completa"
            android:textColor="@color/white"
            app:cornerRadius="4dp"
            app:icon="@android:drawable/ic_menu_mylocation"
            app:iconGravity="top" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnHistory"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:backgroundTint="@color/secondary_green"
            android:text="Historial de viajes"
            android:textColor="@color/white"
            app:cornerRadius="4dp"
            app:icon="@android:drawable/ic_menu_agenda"
            app:iconGravity="top" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>