<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="24dp"
    android:padding="8dp">

    <!-- Avatar Circular -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/ivStudentAvatar"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:scaleType="centerCrop"
        android:src="@android:drawable/ic_menu_myplaces"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:shapeAppearanceOverlay="@style/CircleImage" />

    <!-- Nombre del Estudiante -->
    <TextView
        android:id="@+id/tvStudentName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="Sofia Guzman"
        android:textColor="@color/black"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@+id/btnFinishTrip"
        app:layout_constraintStart_toEndOf="@id/ivStudentAvatar"
        app:layout_constraintTop_toTopOf="@id/ivStudentAvatar" />

    <!-- Etiqueta de Ruta -->
    <TextView
        android:id="@+id/tvRouteLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Ruta: Norte"
        android:textColor="@color/gray_text"
        android:textSize="14sp"
        app:layout_constraintStart_toStartOf="@id/tvStudentName"
        app:layout_constraintTop_toBottomOf="@id/tvStudentName" />

    <!-- Botones de Acción -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnFinishTrip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        android:backgroundTint="@color/secondary_green"
        android:minHeight="48dp"
        android:text="Finalizar\nviaje"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="12sp"
        app:cornerRadius="16dp"
        app:layout_constraintBottom_toBottomOf="@id/tvRouteLabel"
        app:layout_constraintEnd_toStartOf="@+id/btnReportIncident"
        app:layout_constraintTop_toTopOf="@id/tvStudentName" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnReportIncident"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:backgroundTint="#E07C4E"
        android:minHeight="48dp"
        android:text="Reportar\nincidente"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="12sp"
        app:cornerRadius="16dp"
        app:layout_constraintBottom_toBottomOf="@id/btnFinishTrip"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/btnFinishTrip" />

    <!-- Estado con Color dinámico -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Estado: En direccion a destino"
        android:textSize="14sp"
        app:layout_constraintStart_toStartOf="@id/ivStudentAvatar"
        app:layout_constraintTop_toBottomOf="@id/ivStudentAvatar" />

</androidx.constraintlayout.widget.ConstraintLayout>