        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.RideTogether">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".LoginActivity" />
        <activity android:name=".HomeActivity" />
        <activity android:name=".NotificacionesActivity" />
        <activity android:name=".EditarPerfilActivity" />
        <activity android:name=".ReportarIncidenteActivity" />
        <activity android:name=".PantallaPrincipalConductorActivity" />
        <activity android:name=".PantallaPrincipalAdministradorActivity" />
        <activity android:name=".VerRutaConductorActivity" />
        <activity android:name=".VerRutasAdministradorActivity" />
        <activity android:name=".EstudiantesAdministradorActivity" />
        <activity android:name=".DetalleEstudianteActivity" />
        <activity android:name=".RutaCompletaActivity" />
        <activity android:name=".HistorialViajesActivity" />
        <activity android:name=".HistorialIncidentesActivity" />
        <activity android:name=".RegisterTypeActivity" />
        <activity android:name=".RegisterTutorActivity" />
        <activity android:name=".RegisterDriverActivity" />
        <activity android:name=".RegisterInstitutionActivity" />
        <activity android:name=".RegisterSuccessActivity" />
        <activity android:name=".TermsActivity" />
        <activity android:name=".UseAppActivity" />
        <activity android:name=".PrivacyActivity" />
        <activity android:name=".ResponsibilitiesActivity" />
        <activity android:name=".LimitationsActivity" />
        <activity android:name=".IncidentesAdministradorActivity" />

    </application>

</manifest>